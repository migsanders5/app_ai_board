<div class="devise-container">
  <div class="card">
    <h2 style="text-align:center; margin-bottom:1.5rem;">Sign in</h2>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.input :email, required: false, autofocus: true, input_html: { autocomplete: "email" } %>
      <%= f.input :password, required: false, input_html: { autocomplete: "current-password" } %>
      <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>

      <div style="margin-top:1.25rem;">
        <%= f.button :submit, "Sign in", style: "width:100%;" %>
      </div>
    <% end %>

    <div style="margin-top:1rem; font-size:.875rem; text-align:center;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
