<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "UChicago Applied AI Board" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav>
      <span class="nav-brand">Applied AI @ UChicago</span>
      <div class="nav-links">
        <a href="/meetings">Meetings</a>
        <a href="/articles">Articles</a>
        <a href="/jobs">Jobs</a>
      </div>
      <div class="nav-user">
        <% if current_user %>
          <span><%= current_user.name.presence || current_user.email %></span>
          <%= link_to "Sign out", destroy_user_session_path %>
        <% else %>
          <%= link_to "Sign in", new_user_session_path %>
          <%= link_to "Sign up", new_user_registration_path %>
        <% end %>
      </div>
    </nav>

    <% if notice %>
      <p class="flash-notice"><%= notice %></p>
    <% end %>
    <% if alert %>
      <p class="flash-alert"><%= alert %></p>
    <% end %>

    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>
