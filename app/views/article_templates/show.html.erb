<div class="page-actions">
  <a href="/articles">&larr; Back to articles</a>
  <a href="/delete_article/<%= @the_article.id %>" class="btn-danger" data-turbo-prefetch="false">Delete article</a>
</div>

<h1><%= @the_article.article_title %></h1>

<div class="card">
  <dl>
    <dt>Link</dt>
    <dd><a href="<%= @the_article.article_url %>" target="_blank"><%= @the_article.article_url %></a></dd>

    <dt>Caption</dt>
    <dd><%= @the_article.user_caption %></dd>

    <dt>Posted</dt>
    <dd><%= time_ago_in_words(@the_article.created_at) %> ago</dd>
  </dl>
</div>

<div class="card">
  <h2>Comments (<%= @list_of_comments.count %>)</h2>
  <ul class="comment-list">
    <% if @list_of_comments.any? %>
      <% @list_of_comments.each do |a_comment| %>
        <li style="display:flex; justify-content:space-between; align-items:baseline;">
          <span>
            <strong><%= a_comment.user_id %></strong>
            &nbsp;<%= a_comment.comment %>
          </span>
          <a href="/delete_comment/<%= a_comment.id %>" class="btn-danger" data-turbo-prefetch="false" style="font-size:.8rem; white-space:nowrap;">Delete</a>
        </li>
      <% end %>
    <% else %>
      <li><span class="item-meta">No comments yet.</span></li>
    <% end %>
  </ul>

  <hr>

  <h3>Add a comment</h3>
  <form action="/create_comment" method="post">
    <input type="hidden" name="query_article_id" value="<%= @the_article.id %>">
    <div class="form-group">
      <input type="text" name="query_comment" placeholder="Write a comment…">
    </div>
    <button type="submit">Post comment</button>
  </form>
</div>

<div class="card">
  <h2>Edit Article</h2>
  <form action="/modify_article/<%= @the_article.id %>" method="post">
    <div class="form-group">
      <label for="article_title_box">Title</label>
      <input type="text" id="article_title_box" name="query_article_title" value="<%= @the_article.article_title %>">
    </div>
    <div class="form-group">
      <label for="article_url_box">URL</label>
      <input type="text" id="article_url_box" name="query_article_url" value="<%= @the_article.article_url %>">
    </div>
    <div class="form-group">
      <label for="user_caption_box">Caption</label>
      <input type="text" id="user_caption_box" name="query_user_caption" value="<%= @the_article.user_caption %>">
    </div>
    <button type="submit">Update article</button>
  </form>
</div>
