<h1>Jobs &amp; Opportunities</h1>

<style>
  .active-tag {
  border-color: blue;
  }
</style>

<div class="card">
  <h2>Post a New Job</h2>
  <form action="/create_job" method="post">
    <div class="form-group">
      <label for="title_box">Title</label>
      <input type="text" id="title_box" name="query_title">
    </div>
    <div class="form-group">
      <label for="company_box">Company</label>
      <input type="text" id="company_box" name="query_company">
    </div>
    <div class="form-group">
      <label for="application_url_box">Application URL</label>
      <input type="text" id="application_url_box" name="query_application_url">
    </div>
    <div class="form-group">
      <label for="deadline_box">Deadline</label>
      <input type="date" id="deadline_box" name="query_deadline">
    </div>
    <div class="form-group">
      <label for="tag_box">Tag <span style="font-weight:400; color:var(--muted)">(optional, e.g. Python)</span></label>
      <input type="text" id="tag_box" name="query_tag">
    </div>
    <button type="submit">Post job</button>
  </form>
</div>

<div style="display:flex; flex-wrap:wrap; gap:.75rem; align-items:center; margin-bottom:1rem;">
  <div>
    <span style="font-size:.8rem; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:.05em;">Sort:</span>
    <a href="/jobs?<%= @tag_filter.present? ? "tag=#{@tag_filter}&" : "" %>sort=created_at" class="tag-badge" style="margin-left:.35rem;">Date posted</a>
    <a href="/jobs?<%= @tag_filter.present? ? "tag=#{@tag_filter}&" : "" %>sort=deadline" class="tag-badge">Deadline</a>
  </div>
  <% if @all_tags.any? %>
    <div>
      <span style="font-size:.8rem; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:.05em;">Filter:</span>
      <% @all_tags.each do |a_tag| %>
        <a href="/jobs?tag=<%= a_tag %>&sort=<%= @sort %>"
          class="tag-badge <%= 'active-tag' if a_tag == @tag_filter %>"
          style="margin-left:.35rem;">
          <%= a_tag %>
        </a>

      <% end %>
      <% if @tag_filter.present? %>
        <a href="/jobs?sort=<%= @sort %>" style="font-size:.8rem; margin-left:.5rem; color:var(--muted);">Clear filter &times;</a>
      <% end %>
    </div>
  <% end %>
</div>

<div class="card">
  <ul class="item-list">
    <% if @list_of_jobs.any? %>
      <% @list_of_jobs.each do |a_job| %>
        <li style="flex-wrap:wrap; gap:.35rem;">
          <a href="/jobs/<%= a_job.id %>"><%= a_job.title %></a>
          <span class="item-meta"><%= a_job.company %></span>
          <span class="item-meta">
            &mdash; Deadline:
            <%= a_job.deadline.present? ? a_job.deadline.strftime("%b %-d, %Y") : "Not specified" %>
          </span>
          <% a_job.tags.each do |a_tag| %>
            <span class="tag-badge"><%= a_tag.tag %></span>
          <% end %>
        </li>
      <% end %>
    <% else %>
      <li><span class="item-meta">No jobs posted yet.</span></li>
    <% end %>
  </ul>
</div>
